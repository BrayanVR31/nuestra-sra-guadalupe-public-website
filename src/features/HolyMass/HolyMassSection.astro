---
import { Image } from "astro:assets";
import { Calendar } from "@lucide/astro";
import dayjs from "@/libs/dayjs";
import sacramentoImage from "@/assets/images/sacramento.jpg";
import TodayVideo from "./components/TodayVideo";
import VideoPlaylist from "./components/VideoPlaylist";

const nextStreamDate = dayjs()
  .tz()
  .add(1, "day")
  .format("dddd, D [de] MMMM [de] YYYY");
---

<aside
  aria-labelledby="live-stream-title"
  class="py-16 bg-inherit relative min-h-svh flex justify-center flex-col"
>
  <div class="container mx-auto px-4 z-1">
    <header class="flex text-gold-600 gap-4 mb-8">
      <Calendar size={35} class="aspect-square" aria-hidden="true" />
      <div class="flex flex-col">
        <p class="text-sm font-bold uppercase tracking-wider text-neutral-500">
          Próxima transmisión
        </p>
        <time
          datetime={dayjs().add(1, "day").format("YYYY-MM-DD")}
          class="text-lg font-medium text-neutral-800"
        >
          {nextStreamDate}
        </time>
      </div>
    </header>

    <div class="flex md:flex-row flex-col gap-14">
      <article class="flex-1/5" aria-label="Reproductor de video actual">
        <TodayVideo client:load />
      </article>

      <div class="flex-1 flex flex-col justify-center">
        <h2
          id="live-stream-title"
          class="font-primary drop-shadow-md/50 drop-shadow-white mb-6 font-bold text-4xl md:text-start text-center uppercase tracking-wider bg-linear-to-r from-gold-700 via-gold-500 to-gold-700 bg-clip-text text-transparent"
        >
          Santa Misa en Vivo
        </h2>

        <div
          class="space-y-4 mb-8 text-neutral-700 text-center md:text-start text-pretty"
        >
          <p class="text-base/loose drop-shadow-md/50 drop-shadow-white">
            Ofrecemos esta transmisión para que puedas <strong
              class="text-gold-600 font-semibold">unirte espiritualmente</strong
            > a la celebración, especialmente cuando no es posible asistir personalmente.
          </p>
          <p
            class="text-base/loose italic border-l-4 border-gold-500 pl-4 bg-gold-50/50 py-2"
          >
            Bajo circunstancias normales, <strong
              >esta participación no dispensa</strong
            > del deber de asistir a Misa en la asamblea viva de la Iglesia.
          </p>
        </div>

        <nav aria-label="Grabaciones anteriores">
          <VideoPlaylist client:only />
        </nav>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <Image
      class="w-full h-full object-cover grayscale opacity-40 background-image-fade-in"
      src={sacramentoImage}
      alt=""
      fetchpriority="low"
      loading="lazy"
    />
  </div>
</aside>
